<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e"
    android:padding="16dp">

    <!-- Header row: title + status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🎃 Pumpkin Server"
            android:textColor="#ff8c00"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stopped"
            android:textColor="#888888"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Device info line -->
    <TextView
        android:id="@+id/tv_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ABI: ..."
        android:textColor="#666688"
        android:textSize="11sp" />

    <!-- Local IP address (shown while the server is running) -->
    <TextView
        android:id="@+id/tv_ip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#00ff88"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:paddingBottom="8dp" />

    <!-- Start / Stop button -->
    <Button
        android:id="@+id/btn_start_stop"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Start"
        android:textSize="16sp"
        android:textColor="#ffffff"
        android:backgroundTint="#ff8c00"
        android:layout_marginBottom="12dp" />

    <!-- Log section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Server Log"
        android:textColor="#aaaaaa"
        android:textSize="12sp"
        android:paddingBottom="4dp" />

    <!-- Scrollable log output -->
    <ScrollView
        android:id="@+id/scroll_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d0d1a"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#00ff88"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:scrollbars="vertical"
            android:text="Server log will appear here...\n" />
    </ScrollView>

</LinearLayout>
